{
  "expo": {
    "name": "Glowy",
    "slug": "glowy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "dark",
    "scheme": "glowy",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.davideberno.glowy",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Glowy usa la tua posizione per mostrarti l'indice UV della tua zona.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Glowy usa la tua posizione per monitorare l'indice UV e proteggere la tua pelle.",
        "NSLocationAlwaysUsageDescription": "Glowy monitora l'indice UV in base alla tua posizione per inviarti avvisi di sicurezza.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.davideberno.glowy",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Glowy usa la tua posizione per l'indice UV.",
          "locationAlwaysPermission": "Glowy monitora l'UV per la tua sicurezza.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FACC15",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "16dd0c57-7df3-492c-9d6b-7584f5b73225"
      }
    }
  }
}
